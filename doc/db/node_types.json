      "params": [] },

    { "type": "DesignTemplate", "category": "Source", "label": "Design Template",
      "description": "Fixes a mecatronic design point (torque, speed, bus voltage, cooling class). 4 outputs feed sizing nodes.",
      "input_ports": 0, "output_ports": 4,
      "params": [ {"name": "Target Torque", "default": 10.0, "unit": "Nm"},
